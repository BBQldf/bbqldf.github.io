---
layout: null
---
[
{% assign first_item = true %}
{% for post in site.posts %}
{% assign project_key = post.project | default: "default" %}
{% assign project_config = site.data.projects[project_key] %}
{% assign project_visible = true %}
{% if project_config and project_config.visible == false %}
{% assign project_visible = false %}
{% endif %}
{% if project_visible %}
{% unless first_item %},{% endunless %}
{
  "title": {{ post.title | jsonify }},
  "subtitle": {{ post.subtitle | default: "" | jsonify }},
  "url": {{ post.url | prepend: site.baseurl | jsonify }},
  "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
  "project": {{ project_key | jsonify }},
  "tags": {{ post.tags | join: " " | jsonify }},
  "content": {{ post.content | strip_html | strip_newlines | truncate: 600 | jsonify }}
}
{% assign first_item = false %}
{% endif %}
{% endfor %}
{% for post in site.projects %}
{% assign project_key = post.project %}
{% assign project_config = site.data.projects[project_key] %}
{% if project_config and project_config.visible != false %}
{% unless first_item %},{% endunless %}
{
  "title": {{ post.title | jsonify }},
  "subtitle": {{ post.subtitle | default: "" | jsonify }},
  "url": {{ post.url | prepend: site.baseurl | jsonify }},
  "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
  "project": {{ project_key | jsonify }},
  "tags": {{ post.tags | join: " " | jsonify }},
  "content": {{ post.content | strip_html | strip_newlines | truncate: 600 | jsonify }}
}
{% assign first_item = false %}
{% endif %}
{% endfor %}
]
